# Região AWS usada pelo SQS Client (default no código: us-east-1)
AWS_REGION=us-east-1

# Endpoint opcional (útil para LocalStack/desenvolvimento local)
# Exemplo: http://localhost:4566
AWS_SQS_ENDPOINT=

# Credenciais AWS para ambiente local (não use valores reais neste arquivo)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Opcional (quando estiver usando credenciais temporárias)
AWS_SESSION_TOKEN=
